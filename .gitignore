# LabMate code repository (git@github.com:shiinayane/LabMate.git)
# Normal code-repo gitignore: track everything (docs/, src/, configs/, README ...)
# except OS cruft, Python/ML artifacts, and large binaries.
#
# Research notes, papers (References/), proposals and submissions live OUTSIDE this
# repo as sibling folders in the workspace and are never part of it.

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# uv: project-local virtualenv lives in .venv/ (above). uv.lock IS tracked.

# LabUtopia is cloned (not vendored) into src/labutopia/ as its own git repo,
# imported into the unified .venv via PYTHONPATH/.pth. Do NOT track it here.
/src/labutopia/

# ML / run artifacts
outputs/
logs/
wandb/
*.ckpt
*.pth
*.h5

# Large binaries — papers/PDFs must not enter the repo (copyright + size).
# Keep design docs as markdown; cite papers via arXiv links in docs/references.md.
*.pdf
data/
assets/*.usd
